root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

[*.{cs,csx}]
indent_size = 4
# Use file-scoped namespaces
csharp_style_namespace_declarations = file_scoped:warning
csharp_using_directive_placement = outside_namespace:warning
dotnet_sort_system_directives_first = true
csharp_prefer_braces = true:suggestion
dotnet_style_namespace_match_folder = true:suggestion

[*.{csproj,props,targets,config}]
indent_size = 2

[*.{json,yml,yaml}]
indent_size = 2

[*.{cshtml,razor}]
indent_size = 4

[*.md]
trim_trailing_whitespace = false

# EF Core-generated migrations — treat as generated code so our style rules
# (e.g. IDE0161 file-scoped namespaces) don't fail the build on tooling output.
[**/Migrations/*.cs]
generated_code = true
dotnet_diagnostic.IDE0161.severity = none

# Test projects use the conventional Method_Scenario_Expectation naming, which
# trips CA1707 (no underscores in member names). Relax it for tests only.
[tests/**.cs]
dotnet_diagnostic.CA1707.severity = none
