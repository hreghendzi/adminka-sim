<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    adminka-sim restores from nuget.org ONLY. Unlike the adminka platform
    repo, there is no DevExpress proxy feed and no PAT requirement — the sim
    deliberately uses no commercial UI components (plain Razor Pages +
    Bootstrap). Keeping this file explicit prevents a stray machine-level
    NuGet.config from injecting an authenticated feed into the sim build.
  -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
