@page
@model DepositModel
@{
    ViewData["Title"] = "Deposit";
}

<div class="cashier">
    <div class="cashier-head">
        <partial name="_CashierTabs" />
    </div>
    <div class="cashier-body">
        <partial name="_MethodTiles" />

        <div class="row g-4">
            <div class="col-lg-7">
                <div class="method-meta mb-3">
                    <div class="name">AdminkaPay Havale</div>
                    <span class="text-muted">Min: <strong>@PaymentMethods.MinAmount.ToString("N0") TRY</strong>
                        &nbsp;·&nbsp; Max: <strong>@PaymentMethods.MaxAmount.ToString("N0") TRY</strong></span>
                </div>

                @* §3.4 hosted-mode: mirror FASTPAY/jumpobet — open the AdminkaPay hosted
                   page in a NEW TAB (target="_blank") so the casino stays put, exactly like
                   jumpobet's window.open to deposit.fastpayrest.xyz (audit §2 line 50).
                   target="_blank" on a real form submit is a user-gesture navigation, so it
                   is NOT popup-blocked; the casino tab is unchanged and the pool IBAN +
                   countdown + "I've paid" render in the provider tab. *@
                <form method="post" target="_blank" class="mb-2">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>
                    <input type="hidden" asp-for="Method" />

                    <div class="mb-3">
                        <label asp-for="Amount" class="form-label">Amount</label>
                        <div class="input-group">
                            <input asp-for="Amount" class="form-control" type="number" step="1" min="100" max="100000" />
                            <span class="input-group-text">TRY</span>
                        </div>
                        <span asp-validation-for="Amount" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="BankId" class="form-label">Bank</label>
                        @* required → client-side block so the new tab opens only on a valid
                           submit (transfer/Havale always needs a bank). Server-side check in
                           OnPostAsync remains the backstop. *@
                        <select asp-for="BankId" class="form-select" required>
                            <option value="">— select a bank —</option>
                            @foreach (var b in Model.Banks)
                            {
                                <option value="@b.Id">@b.Name@(b.DepositMin is not null ? $" ({b.DepositMin:0}–{b.DepositMax:0} TRY)" : "")</option>
                            }
                        </select>
                        <span asp-validation-for="BankId" class="text-danger"></span>
                        @if (Model.Banks.Count == 0)
                        {
                            <div class="form-text text-warning">No banks available from the gateway right now.</div>
                        }
                    </div>

                    <button type="submit" class="btn btn-primary px-4">Deposit</button>
                    <div class="form-text">The AdminkaPay payment page opens in a new tab.</div>
                </form>

                @if (Model.ResultMessage is not null)
                {
                    <div class="alert @(Model.ResultSuccess ? "alert-success" : "alert-danger") mt-3">@Model.ResultMessage</div>
                }

                @if (Model.PayToAccount is { Count: > 0 })
                {
                    <h2 class="h6 text-muted mt-4 mb-2">Send your Havale to</h2>
                    <div class="pay-card">
                        @foreach (var kv in Model.PayToAccount)
                        {
                            <div class="row-kv"><span class="k">@kv.Key</span><span class="v">@kv.Value</span></div>
                        }
                    </div>
                }
            </div>

            <div class="col-lg-5">
                <div class="payment-info">
                    <h2 class="h6">Payment Info</h2>
                    <p>Our Turkey Fast Bank Transfer (Havale) ensures quick, hassle-free deposits.
                       Enter an amount, pick your bank, and you'll get a pool account to send to.
                       Your balance updates once an operator approves and the confirmation callback lands.</p>
                </div>
            </div>
        </div>
    </div>
</div>

@* Bonus Request — mock modal (everything but deposit/withdraw is mocked).
   Only on the initial view, not after a deposit attempt. *@
@if (Model.ResultMessage is null)
{
<div class="bonus-backdrop" id="bonusBackdrop">
    <div class="bonus-modal">
        <div style="font-size:2rem">🎁</div>
        <h2 class="h5 mt-2">Bonus Request</h2>
        <p class="text-muted">Please select a bonus to receive a reward</p>
        <div class="bonus-card">
            <div class="d-flex justify-content-between"><strong>%100 Casino Yatırım Bonusu</strong><span class="text-muted small">WAGERING</span></div>
            <button type="button" class="btn btn-primary w-100 mt-2" onclick="document.getElementById('bonusBackdrop').style.display='none'">SELECT BONUS</button>
        </div>
        <div class="bonus-card">
            <div class="d-flex justify-content-between"><strong>%25 Çevrimli Spor Yatırım Bonusu</strong><span class="text-muted small">WAGERING</span></div>
            <button type="button" class="btn btn-primary w-100 mt-2" onclick="document.getElementById('bonusBackdrop').style.display='none'">SELECT BONUS</button>
        </div>
        <button type="button" class="btn btn-link w-100" onclick="document.getElementById('bonusBackdrop').style.display='none'">Deposit without reward</button>
    </div>
</div>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
