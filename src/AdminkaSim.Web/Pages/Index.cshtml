@page
@model IndexModel
@{
    ViewData["Title"] = "Lobby";
}

<div class="hero mb-4">
    <h1 class="display-6 mb-1">Welcome back, <span class="lime">@Model.DisplayName</span></h1>
    <p class="text-muted mb-3">Deposit in seconds with Havale and start playing.</p>
    <a class="btn-deposit" asp-page="/Deposit">DEPOSIT NOW</a>
</div>

<div class="row g-4">
    <div class="col-lg-4">
        <div class="card mb-4">
            <div class="card-body">
                <h2 class="h6 text-muted mb-1">Wallet balance</h2>
                <p class="display-6 mb-3">@Model.Balance.ToString("N2") <span class="text-muted h5">@Model.Currency</span></p>
                <div class="d-flex gap-2">
                    <a class="btn btn-primary" asp-page="/Deposit">Deposit</a>
                    <a class="btn btn-outline-primary" asp-page="/Withdraw">Withdraw</a>
                </div>
            </div>
        </div>

        <h2 class="h6 text-muted">Recent activity</h2>
        @if (Model.RecentLedger.Count == 0)
        {
            <p class="text-muted">No transactions yet.</p>
        }
        else
        {
            <table class="table table-sm">
                <thead><tr><th>When</th><th>Type</th><th>Amount</th><th>Status</th></tr></thead>
                <tbody>
                    @foreach (var l in Model.RecentLedger)
                    {
                        <tr>
                            <td class="small">@l.CreatedAt.LocalDateTime.ToString("MM-dd HH:mm")</td>
                            <td>@l.Direction</td>
                            <td>@l.Amount.ToString("N0") @l.Currency</td>
                            <td class="small">@l.Status</td>
                        </tr>
                    }
                </tbody>
            </table>
            <a asp-page="/History" class="btn btn-link px-0">View all transactions →</a>
        }
    </div>

    <div class="col-lg-8">
        @* Mock game lobby — everything but deposit/withdraw is static. *@
        <h2 class="h6 text-muted mb-3">Popular games</h2>
        <div class="game-grid">
            @foreach (var g in new[] { "Sweet Bonanza", "Gates of Olympus", "Live Roulette", "Blackjack VIP", "Mega Wheel", "Aviator", "Big Bass", "Crazy Time", "Book of Dead" })
            {
                <div class="game-tile">@g</div>
            }
        </div>
    </div>
</div>
