@page
@model WithdrawModel
@{
    ViewData["Title"] = "Withdraw";
}

<div class="cashier">
    <div class="cashier-head">
        <partial name="_CashierTabs" />
    </div>
    <div class="cashier-body">
        <partial name="_MethodTiles" />

        <div class="row g-4">
            <div class="col-lg-7">
                <div class="method-meta mb-3">
                    <div class="name">AdminkaPay Havale</div>
                    <span class="text-muted">Available: <strong>@Model.Balance.ToString("N2") TRY</strong>
                        &nbsp;·&nbsp; Min: <strong>@PaymentMethods.MinAmount.ToString("N0") TRY</strong>
                        &nbsp;·&nbsp; Max: <strong>@PaymentMethods.MaxAmount.ToString("N0") TRY</strong></span>
                </div>

                <form method="post" class="mb-2">
                    <div asp-validation-summary="All" class="text-danger mb-2"></div>
                    @* Withdraw is Havale-only; Method is fixed and posted as hidden. *@
                    <input type="hidden" asp-for="Method" />

                    <div class="mb-3">
                        <label asp-for="BankName" class="form-label">Bank</label>
                        <select asp-for="BankName" class="form-select">
                            <option value="">— select your bank —</option>
                            @foreach (var name in TurkishBanks.Names)
                            {
                                <option value="@name">@name</option>
                            }
                        </select>
                        <span asp-validation-for="BankName" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Iban" class="form-label">IBAN</label>
                        <input asp-for="Iban" class="form-control" placeholder="TR33 0006 1005 1978 6457 8413 26" />
                        <span asp-validation-for="Iban" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Amount" class="form-label">Amount</label>
                        <div class="input-group">
                            <input asp-for="Amount" class="form-control" type="number" step="1" min="100" max="100000" placeholder="150" />
                            <span class="input-group-text">TRY</span>
                        </div>
                        <span asp-validation-for="Amount" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn btn-primary px-4">Withdraw</button>
                </form>

                @if (Model.ResultMessage is not null)
                {
                    <div class="alert @(Model.ResultSuccess ? "alert-success" : "alert-danger") mt-3">@Model.ResultMessage</div>
                }
            </div>

            <div class="col-lg-5">
                <div class="payment-info">
                    <h2 class="h6">Payment Info</h2>
                    <p>Withdraw via Havale to your own Turkish bank account. Pick your bank, enter
                       your IBAN and amount; the request stays pending until an operator approves it,
                       and your balance is debited when the confirmation callback lands.</p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
